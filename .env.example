# ============================================================
# SoziBot — Konfigurationsdatei
# Kopiere diese Datei als ".env" und trage deine Keys ein.
# NIEMALS die .env Datei veröffentlichen oder teilen!
# ============================================================

# ── Claude AI (PFLICHT) ──────────────────────────────────────
# Hole deinen Key: https://console.anthropic.com → API Keys
CLAUDE_API_KEY=sk-ant-DEIN_KEY_HIER

# ── E-Mail Benachrichtigungen (optional) ────────────────────
# Gmail: Konto → Sicherheit → App-Passwörter erstellen
NOTIFY_EMAIL=deine@email.de
SMTP_EMAIL=absender@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Instagram ───────────────────────────────────────────────
# Meta for Developers → Deine App → Instagram Graph API
INSTAGRAM_ACCESS_TOKEN=dein_instagram_token
INSTAGRAM_ACCOUNT_ID=deine_numerische_id

# ── Facebook ────────────────────────────────────────────────
# Meta for Developers → Deine App → Pages API
FACEBOOK_ACCESS_TOKEN=dein_facebook_page_token
FACEBOOK_PAGE_ID=deine_page_id

# ── LinkedIn ────────────────────────────────────────────────
# linkedin.com/developers → Create App → OAuth 2.0
LINKEDIN_ACCESS_TOKEN=dein_linkedin_token
LINKEDIN_PERSON_ID=urn:li:person:DEINE_ID

# ── Twitter / X ─────────────────────────────────────────────
# developer.twitter.com → Projects & Apps → Keys and Tokens
TWITTER_BEARER_TOKEN=dein_bearer_token
TWITTER_API_KEY=dein_api_key
TWITTER_API_SECRET=dein_api_secret
TWITTER_ACCESS_TOKEN=dein_access_token
TWITTER_ACCESS_TOKEN_SECRET=dein_access_token_secret

# ── TikTok ──────────────────────────────────────────────────
# developers.tiktok.com → Deine App → Content Posting API
TIKTOK_ACCESS_TOKEN=dein_tiktok_token

# ── Optional: Session Secret ────────────────────────────────
# Wird automatisch generiert wenn leer
# SECRET_KEY=beliebiger_langer_zufallsstring
